# OCR (PaddleOCR)
# Language code passed to PaddleOCR. Default is "en".
PADDLEOCR_LANG=en

# PostgreSQL (SQLAlchemy)
# Works with either:
# - postgresql://user:pass@localhost:5432/document_parsing   (auto-normalized to psycopg v3)
# - postgresql+psycopg://user:pass@localhost:5432/document_parsing
DATABASE_URL=postgresql://user:password@localhost:5432/document_parsing

# Optional: where PaddleX/PaddleOCR stores models/cache.
# If unset, the backend uses `backend/.cache/paddlex`.
PADDLE_PDX_CACHE_HOME=

# Optional: skip connectivity check of model hosters (recommended in restricted networks).
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=true
GROQ_API_KEY=your-groq-api-key-here
